# ===========================================
# Munch AI - Environment Configuration Template
# ===========================================
# Copy this file to .env and fill in your real keys
# cp .env.example .env
#
# NEVER commit .env to Git!

# ===========================================
# AI API Keys
# ===========================================
export YOUTUBE_API_KEY="YOUR_YOUTUBE_API_KEY_HERE"

# Ollama Cloud (legacy support - will be replaced with OpenAI)
export OLLAMA_API_KEY=""

# OpenAI API Key (for production inference)
export OPENAI_API_KEY="sk-your-openai-api-key-here"

# ===========================================
# JWT Authentication - SECURE KEYS
# ===========================================
# Generate a secure key with: openssl rand -hex 32
export JWT_SECRET_KEY="your-secure-secret-key-here-min-64-chars"
export JWT_ALGORITHM="HS256"
export JWT_ACCESS_TOKEN_EXPIRE_MINUTES="30"
export JWT_REFRESH_TOKEN_EXPIRE_DAYS="7"

# ===========================================
# Security Configuration
# ===========================================
# Comma-separated list of allowed CORS origins
# Production: Set to your actual domain(s)
# Example: https://yourdomain.com,https://www.yourdomain.com
export CORS_ALLOWED_ORIGINS="http://localhost:5000,http://localhost:3000"

# ===========================================
# Database Configuration
# ===========================================
# SQLite (development)
export DATABASE_URL="sqlite:///./munch_ai.db"

# PostgreSQL (production) - Uncomment and configure for production
# export DATABASE_URL="postgresql://user:password@localhost:5432/munch_db"

# ===========================================
# Redis Configuration
# ===========================================
export REDIS_URL="redis://localhost:6379/0"

# ===========================================
# Error Tracking (Sentry)
# ===========================================
export SENTRY_DSN=""
export ENVIRONMENT="development"
export APP_VERSION="5.1.0"

# ===========================================
# Email Configuration (for password reset)
# ===========================================
export SMTP_HOST=""
export SMTP_PORT="587"
export SMTP_USER=""
export SMTP_PASSWORD=""
export SMTP_FROM_EMAIL=""
export APP_BASE_URL="http://localhost:5000"

# ===========================================
# Rate Limiting
# ===========================================
export RATE_LIMIT_PER_MINUTE="10"
export RATE_LIMIT_AUTH_PER_MINUTE="5"
